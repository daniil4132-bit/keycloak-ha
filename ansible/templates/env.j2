# VM addresses
VM1_IP={{ vm1_ip }}
VM2_IP={{ vm2_ip }}
VM3_IP={{ vm3_ip }}

# Current host
HOST_IP={{ host_ip }}
HOSTNAME={{ node_hostname }}
ETCD_NAME={{ etcd_name }}
PATRONI_NAME={{ patroni_name }}
NODE_ROLE={{ node_role }}

# Virtual IP
VIP={{ vip }}

# Network interface
INTERFACE={{ interface }}

# Project
COMPOSE_PROJECT_NAME={{ compose_project_name }}

# etcd cluster
ETCD_INITIAL_CLUSTER={{ etcd_initial_cluster }}
ETCD_INITIAL_CLUSTER_TOKEN={{ etcd_initial_cluster_token }}
ETCD_INITIAL_CLUSTER_STATE={{ etcd_initial_cluster_state }}

# PostgreSQL / Patroni
POSTGRES_PASSWORD={{ postgres_password }}
REPLICATION_USERNAME={{ replication_username }}
REPLICATION_PASSWORD={{ replication_password }}
PATRONI_SCOPE={{ patroni_scope }}

# Keycloak database
KEYCLOAK_DB={{ keycloak_db }}
KEYCLOAK_DB_USERNAME={{ keycloak_db_username }}
KEYCLOAK_DB_PASSWORD={{ keycloak_db_password }}

# Keycloak admin
KEYCLOAK_ADMIN={{ keycloak_admin }}
KEYCLOAK_ADMIN_PASSWORD={{ keycloak_admin_password }}

# HAProxy for PostgreSQL
PG_HAPROXY_PORT={{ pg_haproxy_port }}
PG_HAPROXY_STATS_PORT={{ pg_haproxy_stats_port }}

# HAProxy stats
HAPROXY_STATS_USER={{ haproxy_stats_user }}
HAPROXY_STATS_PASSWORD={{ haproxy_stats_password }}

# Keycloak runtime
KEYCLOAK_IMAGE={{ keycloak_image }}
KEYCLOAK_HTTP_PORT={{ keycloak_http_port }}
KEYCLOAK_HOSTNAME={{ keycloak_hostname }}

# Keycloak database connection through local PostgreSQL HAProxy
KEYCLOAK_DB_HOST={{ keycloak_db_host }}
KEYCLOAK_DB_PORT={{ keycloak_db_port }}

# HAProxy for Keycloak
KEYCLOAK_HAPROXY_PORT={{ keycloak_haproxy_port }}
KEYCLOAK_HAPROXY_STATS_PORT={{ keycloak_haproxy_stats_port }}

# UCARP / VIP
UCARP_VHID={{ ucarp_vhid }}
UCARP_PASSWORD={{ ucarp_password }}
UCARP_ADVSKEW={{ ucarp_advskew }}
UCARP_ADVSKEW_VM1={{ ucarp_advskew_vm1 }}
UCARP_ADVSKEW_VM2={{ ucarp_advskew_vm2 }}

# UCARP healthcheck
UCARP_HEALTHCHECK_URL={{ ucarp_healthcheck_url }}
UCARP_HEALTHCHECK_INTERVAL={{ ucarp_healthcheck_interval }}
UCARP_HEALTHCHECK_TIMEOUT={{ ucarp_healthcheck_timeout }}
UCARP_HEALTHCHECK_FAILS={{ ucarp_healthcheck_fails }}
UCARP_HEALTHCHECK_SUCCESS_TO_REJOIN={{ ucarp_healthcheck_success_to_rejoin }}
